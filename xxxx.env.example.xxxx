# Supabase — https://supabase.com/dashboard → Project Settings → API
# Use the public/anon key here, not the service role key.
# Example value prefix: sb_anon_... or the standard anon JWT key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_anon_...

# OpenAI — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Google Books API (optional — raises rate limits)
# https://console.developers.google.com → Enable "Books API" → Create API key
VITE_GOOGLE_BOOKS_API_KEY=
